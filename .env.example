# Copy to .env and fill in values before deploying.
# docker compose picks up .env automatically.

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file inside the backend container
DB_PATH=/data/fakturant.db

# ── Server ────────────────────────────────────────────────────────────────────
# uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info

# ── Local dev only ────────────────────────────────────────────────────────────
# Host port exposed by the frontend container (default 80)
# Not used in production — Caddy binds ports 80/443 instead
FRONTEND_PORT=80

# ── Production (required on Hetzner) ─────────────────────────────────────────
# Your domain name, pointed at the server's IP in DNS
DOMAIN=invoice.example.com

# Email for Let's Encrypt certificate expiry notifications
LETSENCRYPT_EMAIL=you@example.com

# Restrict CORS to your domain. In local dev the default "*" is fine.
ALLOWED_ORIGIN=https://invoice.example.com

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key for signing session cookies (required, minimum 32 chars). Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Allow new user registration (default: true).
# Set to false after initial setup to lock registration.
ALLOW_SIGNUP=true
